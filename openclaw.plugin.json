{
  "id": "openclaw-mailchimp",
  "name": "Mailchimp",
  "description": "Draft, preview, approve, and send Mailchimp email campaigns through conversational chat",
  "version": "1.0.1",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "apiKey": {
        "type": "string"
      },
      "serverPrefix": {
        "type": "string"
      },
      "audienceId": {
        "type": "string"
      }
    }
  },
  "uiHints": {
    "apiKey": {
      "label": "Mailchimp API Key",
      "sensitive": true
    },
    "serverPrefix": {
      "label": "Server Prefix",
      "placeholder": "us14"
    },
    "audienceId": {
      "label": "Audience ID"
    }
  }
}
